# ============================================================
# Next.js / OpenNext / Cloudflare
# ============================================================
.next/
.open-next/
.cache/
.wrangler/

# ============================================================
# Dependencies
# ============================================================
node_modules/

# ============================================================
# Credentials — NEVER commit these
# ============================================================
.dev.vars
.env
.env.*
!.env.example
!.dev.vars.example

# ============================================================
# Build outputs (generated, not source)
# ============================================================
dist/
build/
tsconfig.tsbuildinfo
src/version.json          # generated by scripts/generate-version.mjs at build time

# ============================================================
# OS / Editor
# ============================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ============================================================
# Project-specific
# ============================================================
.kilo/
__pycache__/
test-results/
playwright-report/
playwright/.cache/
temp/
*.log
*.tmp

# ============================================================
# Local D1 data (regenerable)
# ============================================================
.d1/*.sqlite
.d1/*.db
.d1/*.sqlite-shm
.d1/*.sqlite-wal

# ============================================================
# Drizzle generated artifacts (regenerable via drizzle-kit)
# ============================================================
drizzle/meta/