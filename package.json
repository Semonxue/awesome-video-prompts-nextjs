{
  "name": "awesome-video-prompts-nextjs",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js 15 + Cloudflare Workers for Awesome Video Prompts",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "npm run build:cf && wrangler deploy",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:schema:local": "wrangler d1 execute prompts-db --local --file=./drizzle/migrations/0000_init.sql",
    "db:import:local": "tsx scripts/import-md-to-d1.ts --local",
    "db:import:remote": "tsx scripts/import-md-to-d1.ts --remote",
    "dev:cf": "opennextjs-cloudflare dev"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "next": "^15.0.0",
    "next-intl": "^3.26.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@opennextjs/cloudflare": "^1.0.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}